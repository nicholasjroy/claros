# ── Network selection ─────────────────────────────────────────────────────────
# "testnet" (default) or "mainnet". Omit to use testnet.
# DELPHI_NETWORK=testnet

# ── API key (REQUIRED) ────────────────────────────────────────────────────────
DELPHI_API_ACCESS_KEY=

# ── Signer type: "private_key" or "cdp_server_wallet" (default) ──────────────
# DELPHI_SIGNER_TYPE=cdp_server_wallet

# ── Option A: Private key signer ──────────────────────────────────────────────
# Set DELPHI_SIGNER_TYPE=private_key and provide:
# WALLET_PRIVATE_KEY=0x...

# ── Option B: CDP Server Wallet signer (default) ──────────────────────────────
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
CDP_WALLET_ADDRESS=0x...

# ── Optional overrides (set by DELPHI_NETWORK defaults if omitted) ────────────
# GENSYN_RPC_URL=https://gensyn-testnet.g.alchemy.com/public
# GENSYN_CHAIN_ID=685685
# DELPHI_GATEWAY_CONTRACT=0x469388CD2498b43925f562FaA333D95135b66c06
# DELPHI_API_BASE_URL=https://delphi-agentic-trading-api.gensyn-staging.ai/

# ── Cloudflare Access (if the API is behind CF Access) ───────────────────────
# CF_ACCESS_ID=
# CF_ACCESS_SECRET=
